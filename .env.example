# GovIQ DocRoute — local environment template
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
#
# For production, set these via `npx convex env set KEY value` rather than files.

# ---------------------------------------------------------------------------
# Convex
# ---------------------------------------------------------------------------
# Deployment URL from `npx convex dev` output
CONVEX_DEPLOYMENT=

# Public URL for the frontend (Next.js sees this)
NEXT_PUBLIC_CONVEX_URL=

# ---------------------------------------------------------------------------
# Anthropic (Claude API for document extraction)
# ---------------------------------------------------------------------------
# Get from console.anthropic.com. Configure zero-retention on this key before
# any real customer data goes through it.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare R2 (object storage, SaaS default tier)
# ---------------------------------------------------------------------------
# Create a bucket with EU jurisdiction lock — this cannot be changed later.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=goviq-docroute-dev
R2_ENDPOINT=

# ---------------------------------------------------------------------------
# Auth (pick one based on your auth strategy)
# ---------------------------------------------------------------------------
# Clerk
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Or Convex Auth (built-in)
# AUTH_SECRET=

# ---------------------------------------------------------------------------
# Stripe (billing — not needed for MVP)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Observability (not needed for MVP)
# ---------------------------------------------------------------------------
# AXIOM_TOKEN=
# AXIOM_DATASET=

# ---------------------------------------------------------------------------
# Development flags
# ---------------------------------------------------------------------------
# NODE_ENV=development
